#!/usr/bin/env bash
# 推送前检查（warning）
HARNESS_ROOT="${HARNESS_ROOT:-.harness}"

zero="0000000000000000000000000000000000000000"

while read local_ref local_sha remote_ref remote_sha; do
  # 1. 目标分支 master/main 警告
  if [[ "$remote_ref" == *master || "$remote_ref" == *main ]]; then
    echo "[harness] ⚠️ 正在推送到 $remote_ref，违反 R-30-deploy（应走 PR）"
  fi

  # 2. 子模块指针 commit message 检查（在循环内）
  if [ "$remote_sha" = "$zero" ]; then
    # 新分支：与所有 remotes 对比
    range_args=("$local_sha" --not --remotes)
  else
    range_args=("$remote_sha..$local_sha")
  fi

  git log "${range_args[@]}" --pretty=format:"%H %s" 2>/dev/null | while read sha subject; do
    [ -z "$sha" ] && continue
    if git show --pretty="" --name-only "$sha" 2>/dev/null | grep -q "^mooc-manus" && \
       ! echo "$subject" | grep -qE "(升级|upgrade|bump)"; then
      echo "[harness] ⚠️ commit $sha 修改子模块指针但 message 未含'升级' (R-10)"
    fi
  done
done

exit 0
